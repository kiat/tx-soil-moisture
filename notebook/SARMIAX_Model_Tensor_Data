   },
   "outputs": [],
   "source": [
    "# read in the merged station datasets\n",
    "dfs = {}\n",
    "for index in range(0, 6) :\n",
    "  df = pd.read_csv('merged_' + str(index + 1) + '.dat', sep=\",\", parse_dates=[\"Date\"], index_col=\"Date\")\n",
    "  dfs['Station' + str(index + 1)] = df\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {
    "id": "coGrVmWFmZay"
   },
   "outputs": [],
   "source": [
    "#drop these two features because they mess up station 4. Temporary solution\n",
    "\n",
    "for key in dfs.keys():\n",
    "  dfs[key].drop(['SWC_50'], axis = 1, inplace = True)\n",
    "  dfs[key].drop(['T_50'], axis = 1, inplace = True)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "IbivBktfmd8U",
    "outputId": "b9e10542-fe21-44f3-844e-de9139b87c4c"
   },
   "outputs": [],
   "source": [
    "#drop flag feature and null values\n",
    "\n",
    "for station, df in dfs.items() :\n",
    "  # drop the Flag feature (it is not relevant to our soil data and can cause our ML model to pick on unneccesary patterns)\n",
    "  df = df.drop('Flag', axis = 1)\n",
    "  # rename Ppt columns to identify whether the precipitation was recorded as a part of soil data or meteorological data\n",
    "  df_new = df.rename(columns = {'Ppt_x' : 'Ppt_soil', 'Ppt_y': 'Ppt_met'})\n",
    "  df_new.dropna(inplace=True)\n",
    "  dfs[station] = df_new"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {
    "id": "f1q03La7mo53"
   },
   "outputs": [],
   "source": [
    "#Vectorize wind\n",
    "\n",
    "for station, df in dfs.items() :\n",
    "  # convert wind velocity and wind direction to a wind vector\n",
    "  wv = df.pop('Windspeed')\n",
    "\n",
    "  # Convert to radians.\n",
    "  wd_rad = df.pop('Winddirection')*np.pi / 180\n",
    "\n",
    "  # Calculate the wind x and y components.\n",
    "  df['Wx'] = wv*np.cos(wd_rad)\n",
    "  df['Wy'] = wv*np.sin(wd_rad)\n",
    "  dfs[station] = df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {
    "id": "kVfORR_SmpEg"
   },
   "outputs": [],
   "source": [
    "# Remove periodicity in time data (remove daily and yearly periodicity)\n",
    "day = 24*60*60\n",
    "year = (365.2425)*day\n",
    "\n",
    "for station, df in dfs.items() :\n",
    "  timestamp_s = (df.index).map(pd.Timestamp.timestamp)\n",
    "\n",
    "  df['Day sin'] = np.sin(timestamp_s * (2 * np.pi / day))\n",
    "  df['Day cos'] = np.cos(timestamp_s * (2 * np.pi / day))\n",
    "  df['Year sin'] = np.sin(timestamp_s * (2 * np.pi / year))\n",
    "  df['Year cos'] = np.cos(timestamp_s * (2 * np.pi / year))\n",
    "\n",
    "  dfs[station] = df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {
    "id": "QMSBsIunG7yj"
   },
   "outputs": [],
   "source": [
    "# create one standard metric for PPT\n",
    "for key in dfs.keys():\n",
    "  dfs[key]['PPT'] = (dfs[key].pop('Ppt_soil') + dfs[key].pop('Ppt_met'))/2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {
    "id": "0fe82S2LmpJr"
   },
   "outputs": [],
   "source": [
    "#Normalize all the data\n",
    "\n",
    "for key in dfs.keys():\n",
    "  dfs[key] = (dfs[key] - dfs[key].min())/(dfs[key].max()-dfs[key].min())"
   ]
  },
  {
